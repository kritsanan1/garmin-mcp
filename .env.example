# Garmin MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Your Garmin Connect login credentials
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password_here

# Optional: Where to store auth tokens (default: ~/.garmin_mcp_tokens)
# GARMIN_TOKEN_STORE=/home/user/.garmin_mcp_tokens

# Optional: Port for the MCP server (default: 8422)
# GARMIN_MCP_PORT=8422
